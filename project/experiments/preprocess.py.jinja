"""Preprocessing entrypoint for {{ project_name }}.

Dispatches to the task's ``preprocess(cfg)`` function. The framework handles
config-based skip detection (won't re-run if the same config was already
processed) and config-hash-based output directories (multiple preprocessed
versions can coexist).

Task interface (required for preprocessing):
    preprocess(cfg) -> None

The output directory is ``cfg.paths.processed_dir/<hash>/``, where the hash
is derived from the ``preprocess`` config section and ``paths.data_dir``.
The task reads ``cfg.paths.processed_dir`` (already resolved to the hashed
path) and writes its output there.

Usage:
    make preprocess
    make preprocess PREPROCESS_ARGS="preprocess.patch_size=512"
    make preprocess PREPROCESS_ARGS="+experiment=my_experiment"
"""

import importlib
import logging

import hydra
from dotenv import load_dotenv
from omegaconf import DictConfig, OmegaConf

from experiments.config import register_resolvers
from experiments.utils import resolve_processed_dir

load_dotenv()
register_resolvers()

log = logging.getLogger(__name__)


@hydra.main(version_base=None, config_path="../configs", config_name="config")
def main(cfg: DictConfig) -> None:
    # Load task module
    task_name = cfg.get("task", "example")
    task = importlib.import_module(f"experiments.tasks.{task_name}")
    log.info(f"Task: {task_name}")

    preprocess_fn = getattr(task, "preprocess", None)
    if preprocess_fn is None:
        raise AttributeError(
            f"Task '{task_name}' must define preprocess(cfg) for data preprocessing."
        )

    # Resolve config-hash-based output directory
    processed_dir = resolve_processed_dir(cfg)
    config_hash = processed_dir.name

    # Overwrite cfg.paths.processed_dir so the task sees the hashed path
    OmegaConf.update(cfg, "paths.processed_dir", str(processed_dir), force_add=True)

    marker = processed_dir / "preprocess_config.yaml"

    # Skip if already done with same config
    if marker.exists():
        log.info(f"Already preprocessed with this config ({config_hash}), skipping.")
        log.info(f"  Output: {processed_dir}")
        log.info(f"  Remove {marker} to force re-run.")
        return

    log.info(f"Preprocessing [{config_hash}]")
    log.info(f"  Input:  {cfg.paths.data_dir}")
    log.info(f"  Output: {processed_dir}")
    log.info(f"Config:\n{OmegaConf.to_yaml(cfg)}")

    processed_dir.mkdir(parents=True, exist_ok=True)

    # Run task preprocessing
    preprocess_fn(cfg)

    # Save marker (presence = done, config hash in dirname = provenance)
    OmegaConf.save(OmegaConf.create({"hash": config_hash}), marker)

    log.info(f"Preprocessing complete. Output: {processed_dir}")


if __name__ == "__main__":
    main()
