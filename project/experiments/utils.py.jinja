"""Pipeline utilities for {{ project_name }}."""

import hashlib
import logging
from pathlib import Path

from omegaconf import DictConfig, OmegaConf

log = logging.getLogger(__name__)


def resolve_run_hash(cfg: DictConfig) -> str:
    """Compute a short hash from training-relevant config sections.

    Hashes model, data, and training config so that different experiments
    get different output/checkpoint directories. This prevents stale
    checkpoints from one config being auto-resumed by a different config.
    """
    hashable = OmegaConf.to_yaml(OmegaConf.create({
        "model": OmegaConf.to_container(cfg.model, resolve=True),
        "data": OmegaConf.to_container(cfg.data, resolve=True),
        "training": OmegaConf.to_container(cfg.training, resolve=True),
    }))
    return hashlib.sha1(hashable.encode()).hexdigest()[:8]


def resolve_processed_dir(cfg: DictConfig) -> Path:
    """Resolve the config-hash-based processed data directory.

    Computes a hash from preprocessing-relevant config (``preprocess`` section
    + ``paths.data_dir``) and returns ``paths.processed_dir/<hash>``. This
    ensures preprocessing, training, and evaluation all point at the same
    processed data for a given config.

    Returns:
        Path to the hashed processed data directory.
    """
    preprocess_cfg = cfg.get("preprocess") or {}
    if isinstance(preprocess_cfg, DictConfig):
        preprocess_cfg = OmegaConf.to_container(preprocess_cfg, resolve=True)
    hashable = OmegaConf.to_yaml(OmegaConf.create({
        "preprocess": preprocess_cfg,
        "data_dir": str(cfg.paths.data_dir),
    }))
    config_hash = hashlib.sha1(hashable.encode()).hexdigest()[:8]
    return Path(cfg.paths.processed_dir) / config_hash
