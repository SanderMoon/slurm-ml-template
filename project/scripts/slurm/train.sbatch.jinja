#!/bin/bash
# =============================================================================
# Training job — SLURM params injected via sbatch CLI flags from Makefile
#
# Environment variables (set by Makefile --export):
#   NAS_PATH        — project root on NAS
#   NAS_DATA        — data directory (data/raw/, data/processed/)
#   NAS_CHECKPOINTS — checkpoint directory
#   NAS_OUTPUTS     — output directory
# =============================================================================
#SBATCH --open-mode=append
#SBATCH --requeue
#SBATCH --signal=SIGUSR1@120
#SBATCH --mail-type=END,FAIL
#SBATCH --no-container-entrypoint

set -euo pipefail

PROJECT_SLUG="{{ project_slug }}"

echo "======================================================"
echo " Job:          $SLURM_JOB_ID"
echo " Node:         $(hostname)"
echo " GPUs:         $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l)x $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)"
echo " Data:         ${NAS_DATA}"
echo " Checkpoints:  ${NAS_CHECKPOINTS}"
echo " Outputs:      ${NAS_OUTPUTS}"
echo " Date:         $(date)"
echo "======================================================"

# --- Setup ---
# All deps are pre-installed in the Docker image (base → ml-base → project).
# Only need a venv for the editable project link.
export UV_CACHE_DIR="/tmp/uv-cache-${SLURM_JOB_ID}"
VENV="/tmp/venv-${SLURM_JOB_ID}"
uv venv --system-site-packages "${VENV}"
source "${VENV}/bin/activate"
uv pip install -e . --no-deps -q

mkdir -p "${NAS_CHECKPOINTS}" "${NAS_OUTPUTS}"

# --- Distributed env (single-node, auto-detect GPUs) ---
NUM_GPUS=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l)
export MASTER_ADDR=localhost
export MASTER_PORT=29500

# --- Optional: stage data to node-local storage ---
DATA_PATH="${NAS_DATA}"
if [ "${STAGE_DATA:-0}" = "1" ]; then
    LOCAL_DATA="/tmp/data-${SLURM_JOB_ID}"
    echo "Staging data to ${LOCAL_DATA}..."
    mkdir -p "${LOCAL_DATA}"
    rsync -a --info=progress2 "${NAS_DATA}/" "${LOCAL_DATA}/"
    trap 'echo "Cleaning up staged data..."; rm -rf "${LOCAL_DATA}"' EXIT
    DATA_PATH="${LOCAL_DATA}"
    echo "Staging complete ($(du -sh "${LOCAL_DATA}" | cut -f1))"
fi

# --- Train ---
export DATA_DIR="${DATA_PATH}"  # Used by the ${data:name} config resolver
HYDRA_ARGS="paths.checkpoint_dir=${NAS_CHECKPOINTS} paths.data_dir=${DATA_PATH} paths.processed_dir=${DATA_PATH}/processed paths.output_dir=${NAS_OUTPUTS} ${TRAIN_ARGS:-}"

if [ "${NUM_GPUS}" -gt 1 ]; then
    echo "Multi-GPU: launching with accelerate (${NUM_GPUS} GPUs)..."
    accelerate launch --num_processes="${NUM_GPUS}" \
        -m experiments.train ${HYDRA_ARGS}
else
    echo "Single-GPU: direct launch..."
    python -m experiments.train ${HYDRA_ARGS}
fi
echo "Done at $(date)"
